# CareLink backend — copy to .env and fill in

DB_HOST=localhost
DB_USER=root
# Must match MySQL — leave empty ONLY if your user truly has no password (rare on MySQL 8).
DB_PASSWORD=
DB_NAME=carelink

# --- Email (signup / password-reset codes) ---
# Gmail: use an App Password (Google Account → Security → 2-Step → App passwords)
MAIL_USER=you@gmail.com
MAIL_PASS=your-16-char-app-password
# Optional display name / envelope:
# MAIL_FROM="CareLink" <you@gmail.com>

# Generic SMTP (Outlook, corporate, SendGrid SMTP relay, etc.):
# MAIL_HOST=smtp.office365.com
# MAIL_PORT=587
# MAIL_SECURE=false
# For Gmail you can omit MAIL_* host — Nodemailer uses service "gmail" by default.

# --- Dev only ---
# NODE_ENV=development
# Return verification code in API JSON for the mobile app (default in non-production).
# Set to 0 to hide code from JSON (you must rely on real inbox + server logs).
# CARELINK_EXPOSE_DEV_CODES=1
