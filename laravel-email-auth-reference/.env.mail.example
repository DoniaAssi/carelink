# Append or merge into Laravel .env — OTP is never returned in API JSON.

MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=you@gmail.com
MAIL_PASSWORD=your-16-char-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=you@gmail.com
MAIL_FROM_NAME="CareLink"

# Gmail: Account → Security → 2-Step Verification → App passwords → create "Mail".
# Use the generated password as MAIL_PASSWORD (not your normal Google password).

# Office 365 example:
# MAIL_HOST=smtp.office365.com
# MAIL_PORT=587
# MAIL_ENCRYPTION=tls
