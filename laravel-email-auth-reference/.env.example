# =============================================================================
# REFERENCE ONLY — CareLink Flutter uses the NODE backend by default.
# Put SMTP for the mobile app in:  carelink-main/backend/.env  (MAIL_USER, MAIL_PASS)
#
# Use THIS file only if you run a real Laravel app and merge these routes/models.
# Copy to .env in that Laravel project root and fill real values (never commit .env).
# =============================================================================

APP_NAME=CareLink
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=carelink
DB_USERNAME=root
DB_PASSWORD=

# Laravel mail (Gmail: App Password as MAIL_PASSWORD — not your normal Google password)
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=you@gmail.com
MAIL_PASSWORD=your-16-char-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=you@gmail.com
MAIL_FROM_NAME="${APP_NAME}"

# Office 365 example:
# MAIL_HOST=smtp.office365.com
# MAIL_PORT=587
# MAIL_ENCRYPTION=tls
